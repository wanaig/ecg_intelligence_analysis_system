# ============================================
# ECG 智能分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# 服务端口
SERVER_PORT=8080

# MySQL 数据库连接
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=ecg_intelligence_analysis_system
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT 签名密钥（HS256 至少 32 字节）
JWT_SECRET_KEY=your_jwt_secret_key_at_least_32_bytes_long
JWT_EXPIRATION_MINUTES=120
JWT_ISSUER=ecg-collection
